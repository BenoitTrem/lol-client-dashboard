{
  "main": "electron/main.js",
  "name": "lcu-dashboard",
  "version": "1.0.0",
  "private": true,
  "build": {
    "appId": "com.yourname.lcu-dashboard",
    "productName": "LoL_Dashboard",
    "forceCodeSigning": false,
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "icon": "resources/icon.ico",
      "target": "nsis"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "dist": "next build && electron-builder",
    "dist-win": "electron-builder --win",
    "start": "next start",
    "electron": "electron .",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\""
  },
  "dependencies": {
    "electron-reload": "^2.0.0-alpha.1",
    "https": "^1.0.0",
    "lucide-react": "^1.17.0",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^10.0.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
